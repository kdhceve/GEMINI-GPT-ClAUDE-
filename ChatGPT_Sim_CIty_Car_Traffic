import pygame
import random
import math
import heapq

# =========================
# CONFIG
# =========================
WIDTH, HEIGHT = 800, 800
GRID_SIZE = 40
CELL = WIDTH // GRID_SIZE

ROAD = 1
EMPTY = 0

CAR_COUNT = 30

# =========================
# GRID GENERATION
# =========================
def generate_city():
    grid = [[EMPTY for _ in range(GRID_SIZE)] for _ in range(GRID_SIZE)]

    # X/Z alignment style roads
    for i in range(0, GRID_SIZE, 4):
        for j in range(GRID_SIZE):
            grid[i][j] = ROAD
            grid[j][i] = ROAD

    return grid

# =========================
# PATHFINDING (A*)
# =========================
def heuristic(a, b):
    return abs(a[0]-b[0]) + abs(a[1]-b[1])


def astar(grid, start, goal):
    open_set = []
    heapq.heappush(open_set, (0, start))

    came_from = {}
    g_score = {start: 0}

    while open_set:
        _, current = heapq.heappop(open_set)

        if current == goal:
            path = []
            while current in came_from:
                path.append(current)
                current = came_from[current]
            path.reverse()
            return path

        x, y = current
        for dx, dy in [(1,0),(-1,0),(0,1),(0,-1)]:
            nx, ny = x+dx, y+dy
            if 0 <= nx < GRID_SIZE and 0 <= ny < GRID_SIZE:
                if grid[nx][ny] != ROAD:
                    continue

                neighbor = (nx, ny)
                tentative = g_score[current] + 1

                if neighbor not in g_score or tentative < g_score[neighbor]:
                    came_from[neighbor] = current
                    g_score[neighbor] = tentative
                    f = tentative + heuristic(neighbor, goal)
                    heapq.heappush(open_set, (f, neighbor))

    return []

# =========================
# CAR CLASS
# =========================
class Car:
    def __init__(self, grid):
        self.grid = grid
        self.pos = self.random_road()
        self.target = self.random_road()
        self.path = astar(grid, self.pos, self.target)
        self.color = [random.randint(100,255) for _ in range(3)]
        self.speed = random.uniform(2,4)
        self.progress = 0

    def random_road(self):
        while True:
            x = random.randint(0, GRID_SIZE-1)
            y = random.randint(0, GRID_SIZE-1)
            if self.grid[x][y] == ROAD:
                return (x,y)

    def update(self):
        if not self.path:
            self.target = self.random_road()
            self.path = astar(self.grid, self.pos, self.target)
            return

        self.progress += self.speed * 0.05

        if self.progress >= 1:
            self.pos = self.path.pop(0)
            self.progress = 0

    def draw(self, screen):
        if not self.path:
            return

        x, y = self.pos
        px = x * CELL + CELL//2
        py = y * CELL + CELL//2

        pygame.draw.circle(screen, self.color, (px, py), CELL//4)

# =========================
# MAIN LOOP
# =========================
def main():
    pygame.init()
    screen = pygame.display.set_mode((WIDTH, HEIGHT))
    clock = pygame.time.Clock()

    grid = generate_city()
    cars = [Car(grid) for _ in range(CAR_COUNT)]

    running = True
    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False

        # UPDATE
        for car in cars:
            car.update()

        # DRAW
        screen.fill((10,10,10))

        # draw grid
        for x in range(GRID_SIZE):
            for y in range(GRID_SIZE):
                if grid[x][y] == ROAD:
                    pygame.draw.rect(screen, (60,60,60), (x*CELL, y*CELL, CELL, CELL))

        # draw cars
        for car in cars:
            car.draw(screen)

        pygame.display.flip()
        clock.tick(60)

    pygame.quit()

if __name__ == "__main__":
    main()
